{
  "uid": "judgemesh-oj-live",
  "title": "JudgeMesh OJ Live",
  "tags": ["judgemesh", "business"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Gateway QPS",
      "gridPos": {"x": 0, "y": 0, "w": 4, "h": 4},
      "targets": [{"expr": "sum(rate(http_server_requests_seconds_count{application=\"gateway\"}[5m]))"}]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Submit QPS",
      "gridPos": {"x": 4, "y": 0, "w": 4, "h": 4},
      "targets": [{"expr": "sum(rate(http_server_requests_seconds_count{application=\"submit-service\",uri=~\"/api/submit.*|/api/submits.*\"}[5m]))"}]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Accepted Ratio",
      "gridPos": {"x": 8, "y": 0, "w": 4, "h": 4},
      "targets": [{"expr": "sum(rate(oj_judge_total{verdict=\"ac\"}[5m])) / clamp_min(sum(rate(oj_judge_total[5m])), 1)"}]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Queue Ready",
      "gridPos": {"x": 12, "y": 0, "w": 4, "h": 4},
      "targets": [{"expr": "sum(rabbitmq_queue_messages_ready{queue=\"submit.queue\"})"}]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Workers Up",
      "gridPos": {"x": 16, "y": 0, "w": 4, "h": 4},
      "targets": [{"expr": "sum(oj_worker_up)"}]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "In-flight Judges",
      "gridPos": {"x": 20, "y": 0, "w": 4, "h": 4},
      "targets": [{"expr": "sum(oj_judge_inflight)"}]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "HTTP p95 by Service",
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8},
      "targets": [{"expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=~\"gateway|user-service|problem-service|submit-service|judge-dispatcher\"}[5m])) by (le, application))"}]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Judge p95 by Language",
      "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8},
      "targets": [{"expr": "histogram_quantile(0.95, sum(rate(oj_judge_duration_seconds_bucket[5m])) by (le, language))"}]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Judge Verdict Rate",
      "gridPos": {"x": 0, "y": 12, "w": 12, "h": 8},
      "targets": [{"expr": "sum(rate(oj_judge_total[5m])) by (verdict)"}]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Request Error Rate",
      "gridPos": {"x": 12, "y": 12, "w": 12, "h": 8},
      "targets": [{"expr": "sum(rate(http_server_requests_seconds_count{status=~\"4..|5..\"}[5m])) by (application, status)"}]
    }
  ]
}
