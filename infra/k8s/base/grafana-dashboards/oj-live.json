{
  "uid": "judgemesh-oj-live",
  "title": "JudgeMesh OJ Live",
  "tags": ["judgemesh", "business"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Gateway QPS",
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
      "targets": [{"expr": "sum(rate(http_server_requests_seconds_count{application=\"gateway\"}[5m]))"}]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Submit Rate",
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
      "targets": [{"expr": "sum(rate(http_server_requests_seconds_count{application=\"submit-service\",uri=~\"/api/submit.*\"}[5m]))"}]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Service Request Latency p95",
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8},
      "targets": [{"expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket[5m])) by (le, application))"}]
    }
  ]
}
