{
  "uid": "judgemesh-governance",
  "title": "JudgeMesh Governance",
  "tags": ["judgemesh", "governance"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "HTTP 4xx/5xx by Service",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "targets": [{"expr": "sum(rate(http_server_requests_seconds_count{status=~\"4..|5..\"}[5m])) by (application, status)"}]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Circuit Breaker Calls",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "targets": [{"expr": "sum(rate(resilience4j_circuitbreaker_calls_seconds_count[5m])) by (name, kind)"}]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Dispatcher Leaders",
      "gridPos": {"x": 0, "y": 8, "w": 6, "h": 4},
      "targets": [{"expr": "sum(up{job=~\".*judge-dispatcher.*\"})"}]
    }
  ]
}
